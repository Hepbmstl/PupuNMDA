<Window x:Class="NeuronCAD.Visuals.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helix="http://helix-toolkit.org/wpf"
        xmlns:vtkTab="clr-namespace:NeuronCAD.Visuals.Tabs.VTK"
        mc:Ignorable="d"
        Title="NeuronCAD 2026"
        Height="768"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Menu Bar -->
                <Border Grid.Row="0"
                        Background="#2D2D30"
                        BorderBrush="#3F3F46"
                        BorderThickness="0,0,0,1">
                        <Menu Background="Transparent"
                              Foreground="#F1F1F1"
                              Margin="5">
                                <Menu.Resources>
                                        <Style TargetType="MenuItem">
                                                <Setter Property="Foreground"
                                                        Value="Black"/>
                                                <Setter Property="FontSize"
                                                        Value="12"/>
                                                <Setter Property="Padding"
                                                        Value="10,5"/>
                                                <Style.Triggers>
                                                        <Trigger Property="Role"
                                                                 Value="TopLevelHeader">
                                                                <Setter Property="Foreground"
                                                                        Value="#F1F1F1"/>
                                                        </Trigger>
                                                        <Trigger Property="Role"
                                                                 Value="TopLevelItem">
                                                                <Setter Property="Foreground"
                                                                        Value="#F1F1F1"/>
                                                        </Trigger>
                                                </Style.Triggers>
                                        </Style>
                                </Menu.Resources>
                                <MenuItem Header="File">
                                        <MenuItem Header="New Project"
                                                  Click="OnNewProjectClick"/>
                                        <MenuItem Header="Open..."
                                                  Click="OnOpenProjectClick"/>
                                        <MenuItem Header="Save"
                                                  Click="OnSaveProjectClick"/>
                                        <MenuItem Header="Save As..."
                                                  Click="OnSaveAsProjectClick"/>
                                        <Separator/>
                                        <MenuItem Header="Exit"
                                                  Click="OnExitClick"/>
                                </MenuItem>
                                <MenuItem Header="Edit">
                                        <MenuItem Header="Ion Channel Setting"
                                                  Click="OnIonChannelSettingClick"/>
                                </MenuItem>
                                <MenuItem Header="Data">
                                        <MenuItem Header="Export Simulation Data..."
                                                  x:Name="MenuExportSimData"
                                                  Click="OnExportSimulationDataClick"/>
                                        <MenuItem Header="Import Simulation Data..."
                                                  x:Name="MenuImportSimData"
                                                  Click="OnImportSimulationDataClick"/>
                                </MenuItem>
                                <MenuItem Header="Help"/>
                        </Menu>
                </Border>

                <!-- Row 1: Top-level tab bar (Modeling / Simulating / Reporting) -->
                <Border Grid.Row="1"
                        Background="#2D2D30"
                        BorderBrush="#3F3F46"
                        BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal"
                                    Margin="5,0,0,0">
                                <ToggleButton x:Name="TabModeling"
                                              Content="Modeling"
                                              IsChecked="True"
                                              Click="OnTabModelingClick"
                                              Padding="18,7"
                                              MinWidth="90"
                                              Background="#3E3E42"
                                              Foreground="White"
                                              BorderThickness="0"
                                              Margin="0,0,2,0"/>
                                <ToggleButton x:Name="TabSimulation"
                                              Content="Simulating"
                                              Click="OnTabSimulationClick"
                                              Padding="18,7"
                                              MinWidth="90"
                                              Background="#3E3E42"
                                              Foreground="White"
                                              BorderThickness="0"
                                              Margin="0,0,2,0"/>
                                <ToggleButton x:Name="TabReporting"
                                              Content="Reporting"
                                              Click="OnTabReportingClick"
                                              Padding="18,7"
                                              MinWidth="90"
                                              Background="#3E3E42"
                                              Foreground="White"
                                              BorderThickness="0"
                                              Margin="0,0,2,0"/>
                                <ToggleButton x:Name="TabVTK"
                                              Content="VTK"
                                              Click="OnTabVTKClick"
                                              Padding="18,7"
                                              MinWidth="90"
                                              Background="#3E3E42"
                                              Foreground="White"
                                              BorderThickness="0"
                                              Margin="0,0,2,0"/>
                        </StackPanel>
                </Border>

                <!-- Row 2: Tab content (panel + viewport) -->
                <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left sidebar panel -->
                        <Border Grid.Column="0"
                                Background="#252526"
                                BorderBrush="#3F3F46"
                                BorderThickness="0,0,1,0">
                                <Grid>
                                        <!-- Modeling panel -->
                                        <ScrollViewer x:Name="ModelingPanelScroll"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Visibility="Visible">
                                                <StackPanel x:Name="ModelingPanelContainer"
                                                            Margin="5"/>
                                        </ScrollViewer>

                                        <!-- Simulating panel (with Insert / Simulate sub-tabs) -->
                                        <Grid x:Name="SimulatingPanelRoot"
                                              Visibility="Collapsed">
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- Sub-tab buttons -->
                                                <StackPanel Grid.Row="0"
                                                            Orientation="Horizontal"
                                                            Background="#1E1E1E"
                                                            Margin="0,0,0,1">
                                                        <ToggleButton x:Name="SubTabInsert"
                                                                      Content="Insert"
                                                                      IsChecked="True"
                                                                      Click="OnSubTabInsertClick"
                                                                      Padding="14,5"
                                                                      MinWidth="70"
                                                                      Background="#333337"
                                                                      Foreground="White"
                                                                      BorderThickness="0"
                                                                      Margin="4,4,2,4"/>
                                                        <ToggleButton x:Name="SubTabSimulate"
                                                                      Content="Simulate"
                                                                      Click="OnSubTabSimulateClick"
                                                                      Padding="14,5"
                                                                      MinWidth="70"
                                                                      Background="#333337"
                                                                      Foreground="White"
                                                                      BorderThickness="0"
                                                                      Margin="0,4,4,4"/>
                                                </StackPanel>

                                                <!-- Insert sub-tab content: devices list -->
                                                <ScrollViewer x:Name="InsertPanelScroll"
                                                              Grid.Row="1"
                                                              VerticalScrollBarVisibility="Auto"
                                                              Visibility="Visible">
                                                        <StackPanel x:Name="SimulationPanelContainer"
                                                                    Margin="5"/>
                                                </ScrollViewer>

                                                <!-- Simulate sub-tab content: parameter inputs + Begin button -->
                                                <ScrollViewer x:Name="SimulatePanelScroll"
                                                              Grid.Row="1"
                                                              VerticalScrollBarVisibility="Auto"
                                                              Visibility="Collapsed">
                                                        <StackPanel Margin="10">
                                                                <TextBlock x:Name="ProjectNameLabel"
                                                                           Text="Project: (none)"
                                                                           Foreground="#FFD700"
                                                                           FontWeight="Bold"
                                                                           FontSize="13"
                                                                           Margin="0,0,0,12"
                                                                           TextWrapping="Wrap"/>

                                                                <TextBlock Text="Simulation Parameters"
                                                                           Foreground="White"
                                                                           FontWeight="Bold"
                                                                           FontSize="14"
                                                                           Margin="0,0,0,12"/>

                                                                <TextBlock Text="V_init (mV):"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBox x:Name="TbVInit"
                                                                         Text="-70"
                                                                         Background="#2A2A2A"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"
                                                                         Padding="4"
                                                                         Margin="0,0,0,8"/>

                                                                <TextBlock Text="dt (ms):"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBox x:Name="TbDt"
                                                                         Text="0.1"
                                                                         Background="#2A2A2A"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"
                                                                         Padding="4"
                                                                         Margin="0,0,0,8"/>

                                                                <TextBlock Text="Steps:"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBox x:Name="TbSteps"
                                                                         Text="10000"
                                                                         Background="#2A2A2A"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"
                                                                         Padding="4"
                                                                         Margin="0,0,0,8"/>

                                                                <TextBlock Text="E_Na (mV):"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBox x:Name="TbENa"
                                                                         Text="50"
                                                                         Background="#2A2A2A"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"
                                                                         Padding="4"
                                                                         Margin="0,0,0,8"/>

                                                                <TextBlock Text="E_K (mV):"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBox x:Name="TbEK"
                                                                         Text="-90"
                                                                         Background="#2A2A2A"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"
                                                                         Padding="4"
                                                                         Margin="0,0,0,8"/>

                                                                <TextBlock Text="E_Leak (mV):"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBox x:Name="TbELeak"
                                                                         Text="-76.5"
                                                                         Background="#2A2A2A"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"
                                                                         Padding="4"
                                                                         Margin="0,0,0,8"/>

                                                                <TextBlock Text="Celsius (°C):"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBox x:Name="TbCelsius"
                                                                         Text="24"
                                                                         Background="#2A2A2A"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"
                                                                         Padding="4"
                                                                         Margin="0,0,0,8"/>

                                                                <TextBlock Text="Ca_out (mM):"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBox x:Name="TbCaOut"
                                                                         Text="2.0"
                                                                         Background="#2A2A2A"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"
                                                                         Padding="4"
                                                                         Margin="0,0,0,8"/>

                                                                <TextBlock Text="Ca_inf (mM):"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBox x:Name="TbCaInf"
                                                                         Text="2.4e-4"
                                                                         Background="#2A2A2A"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"
                                                                         Padding="4"
                                                                         Margin="0,0,0,8"/>

                                                                <TextBlock Text="Tau_Ca (ms):"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBox x:Name="TbTauCa"
                                                                         Text="5.0"
                                                                         Background="#2A2A2A"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"
                                                                         Padding="4"
                                                                         Margin="0,0,0,16"/>

                                                                <TextBlock Text="Segmentation"
                                                                           Foreground="White"
                                                                           FontWeight="Bold"
                                                                           FontSize="14"
                                                                           Margin="0,0,0,8"/>

                                                                <StackPanel Orientation="Horizontal"
                                                                            Margin="0,0,0,8">
                                                                        <RadioButton x:Name="RbNSeg"
                                                                                     Content="NSeg"
                                                                                     IsChecked="True"
                                                                                     Foreground="#CCC"
                                                                                     GroupName="SegMode"
                                                                                     Margin="0,0,15,0"/>
                                                                        <RadioButton x:Name="RbLSeg"
                                                                                     Content="LSeg"
                                                                                     Foreground="#CCC"
                                                                                     GroupName="SegMode"/>
                                                                </StackPanel>

                                                                <TextBlock Text="NSeg (compartments per segment):"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBox x:Name="TbNSeg"
                                                                         Text="5"
                                                                         Background="#2A2A2A"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"
                                                                         Padding="4"
                                                                         Margin="0,0,0,8"/>

                                                                <TextBlock Text="LSeg (µm, compartment spacing):"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"
                                                                           Margin="0,0,0,2"/>
                                                                <TextBox x:Name="TbLSeg"
                                                                         Text="20"
                                                                         Background="#2A2A2A"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"
                                                                         Padding="4"
                                                                         Margin="0,0,0,16"/>

                                                                <Button x:Name="BtnBeginSimulation"
                                                                        Content="Begin"
                                                                        Click="OnBeginSimulationClick"
                                                                        Background="{StaticResource PrimaryActionBrush}"
                                                                        Foreground="White"
                                                                        FontWeight="Bold"
                                                                        FontSize="14"
                                                                        Padding="10,8"
                                                                        HorizontalAlignment="Stretch"
                                                                        Cursor="Hand">
                                                                        <Button.Template>
                                                                                <ControlTemplate TargetType="Button">
                                                                                        <Border Background="{TemplateBinding Background}"
                                                                                                CornerRadius="4"
                                                                                                Padding="{TemplateBinding Padding}">
                                                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                                                  VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                </ControlTemplate>
                                                                        </Button.Template>
                                                                </Button>

                                                                <!-- Simulation Progress Panel -->
                                                                <StackPanel x:Name="SimProgressPanel"
                                                                            Visibility="Collapsed"
                                                                            Margin="0,12,0,0">
                                                                        <Border Background="#1E1E1E"
                                                                                CornerRadius="4"
                                                                                Padding="8">
                                                                                <StackPanel>
                                                                                        <TextBlock x:Name="SimStatusText"
                                                                                                   Text="Initializing..."
                                                                                                   Foreground="#FFD700"
                                                                                                   FontWeight="Bold"
                                                                                                   Margin="0,0,0,4"/>
                                                                                        <TextBlock x:Name="SimStepText"
                                                                                                   Text="Step: 0 / 0"
                                                                                                   Foreground="#AAAAAA"
                                                                                                   FontSize="11"
                                                                                                   Margin="0,0,0,6"/>
                                                                                        <ProgressBar x:Name="SimProgressBar"
                                                                                                     Minimum="0"
                                                                                                     Maximum="100"
                                                                                                     Value="0"
                                                                                                     Height="8"
                                                                                                     Foreground="#007ACC"
                                                                                                     Background="#333333"/>
                                                                                        <Button x:Name="BtnAbortSimulation"
                                                                                                Content="Abort"
                                                                                                Click="OnAbortSimulationClick"
                                                                                                Background="#C42B1C"
                                                                                                Foreground="White"
                                                                                                FontWeight="Bold"
                                                                                                Padding="8,4"
                                                                                                Margin="0,8,0,0"
                                                                                                HorizontalAlignment="Stretch"
                                                                                                Cursor="Hand"/>
                                                                                </StackPanel>
                                                                        </Border>
                                                                </StackPanel>
                                                        </StackPanel>
                                                </ScrollViewer>
                                        </Grid>

                                        <!-- Reporting panel (with Components / Probes sub-tabs) -->
                                        <Grid x:Name="ReportingPanelRoot"
                                              Visibility="Collapsed">
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- Sub-tab buttons -->
                                                <StackPanel Grid.Row="0"
                                                            Orientation="Horizontal"
                                                            Background="#1E1E1E"
                                                            Margin="0,0,0,1">
                                                        <ToggleButton x:Name="ReportSubTabComponents"
                                                                      Content="Components"
                                                                      IsChecked="True"
                                                                      Click="OnReportSubTabComponentsClick"
                                                                      Padding="14,5"
                                                                      MinWidth="70"
                                                                      Background="#333337"
                                                                      Foreground="White"
                                                                      BorderThickness="0"
                                                                      Margin="4,4,2,4"/>
                                                        <ToggleButton x:Name="ReportSubTabProbes"
                                                                      Content="Probes"
                                                                      Click="OnReportSubTabProbesClick"
                                                                      Padding="14,5"
                                                                      MinWidth="70"
                                                                      Background="#333337"
                                                                      Foreground="White"
                                                                      BorderThickness="0"
                                                                      Margin="0,4,4,4"/>
                                                </StackPanel>

                                                <!-- Components sub-tab -->
                                                <ScrollViewer x:Name="ReportComponentsScroll"
                                                              Grid.Row="1"
                                                              VerticalScrollBarVisibility="Auto"
                                                              Visibility="Visible">
                                                        <StackPanel x:Name="ReportComponentsContainer"
                                                                    Margin="5"/>
                                                </ScrollViewer>

                                                <!-- Probes sub-tab -->
                                                <ScrollViewer x:Name="ReportProbesScroll"
                                                              Grid.Row="1"
                                                              VerticalScrollBarVisibility="Auto"
                                                              Visibility="Collapsed">
                                                        <StackPanel x:Name="ReportProbesContainer"
                                                                    Margin="5"/>
                                                </ScrollViewer>
                                        </Grid>

                                        <!-- VTK panel (with Controls / Channels sub-tabs) -->
                                        <Grid x:Name="VTKPanelRoot"
                                              Visibility="Collapsed">
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0"
                                                      Background="#1E1E1E"
                                                      Margin="0,0,0,1">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ToggleButton x:Name="VTKSubTabControls"
                                                                      Grid.Column="0"
                                                                      Content="Controls"
                                                                      IsChecked="True"
                                                                      Click="OnVTKSubTabControlsClick"
                                                                      Padding="8,5"
                                                                      HorizontalAlignment="Stretch"
                                                                      Background="#333337"
                                                                      Foreground="White"
                                                                      BorderThickness="0"
                                                                      Margin="4,4,2,4"/>
                                                        <ToggleButton x:Name="VTKSubTabChannels"
                                                                      Grid.Column="1"
                                                                      Content="Channels"
                                                                      Click="OnVTKSubTabChannelsClick"
                                                                      Padding="8,5"
                                                                      HorizontalAlignment="Stretch"
                                                                      Background="#333337"
                                                                      Foreground="White"
                                                                      BorderThickness="0"
                                                                      Margin="2,4,2,4"/>
                                                        <ToggleButton x:Name="VTKSubTabHistory"
                                                                      Grid.Column="2"
                                                                      Content="History"
                                                                      Click="OnVTKSubTabHistoryClick"
                                                                      Padding="8,5"
                                                                      HorizontalAlignment="Stretch"
                                                                      Background="#333337"
                                                                      Foreground="White"
                                                                      BorderThickness="0"
                                                                      Margin="2,4,4,4"/>
                                                </Grid>

                                                <ScrollViewer x:Name="VTKControlsScroll"
                                                              Grid.Row="1"
                                                              VerticalScrollBarVisibility="Auto"
                                                              Visibility="Visible">
                                                        <StackPanel Margin="10">
                                                                <TextBlock Text="VTK Viewer"
                                                                           Foreground="White"
                                                                           FontWeight="Bold"
                                                                           FontSize="14"
                                                                           Margin="0,0,0,12"/>

                                                                <Button x:Name="BtnLaunchVTK"
                                                                        Content="Launch VTK Viewer"
                                                                        Click="OnLaunchVTKClick"
                                                                        Background="{StaticResource PrimaryActionBrush}"
                                                                        Foreground="White"
                                                                        Padding="10,7"
                                                                        HorizontalAlignment="Stretch"
                                                                        Margin="0,0,0,8"/>

                                                                <Button x:Name="BtnRenderVTKJsonColors"
                                                                        Content="Render Original Colors"
                                                                        Click="OnRenderVTKJsonColorsClick"
                                                                        Background="#3E3E42"
                                                                        Foreground="White"
                                                                        Padding="10,7"
                                                                        HorizontalAlignment="Stretch"
                                                                        Margin="0,0,0,8"/>

                                                                <Button x:Name="BtnStopVTK"
                                                                        Content="Stop VTK Viewer"
                                                                        Click="OnStopVTKClick"
                                                                        Background="#3E3E42"
                                                                        Foreground="White"
                                                                        Padding="10,7"
                                                                        HorizontalAlignment="Stretch"
                                                                        Margin="0,0,0,14"/>

                                                                <TextBlock Text="Display"
                                                                           Foreground="White"
                                                                           FontWeight="Bold"
                                                                           FontSize="14"
                                                                           Margin="0,0,0,8"/>

                                                                <CheckBox x:Name="ChkVTKConnections"
                                                                          Content="Connections"
                                                                          Foreground="#CCCCCC"
                                                                          Margin="0,0,0,6"/>
                                                                <CheckBox x:Name="ChkVTKDevices"
                                                                          Content="Devices"
                                                                          IsChecked="True"
                                                                          Foreground="#CCCCCC"
                                                                          Margin="0,0,0,12"/>

                                                                <StackPanel Orientation="Horizontal"
                                                                            Margin="0,0,0,4">
                                                                        <TextBlock Text="Shadow"
                                                                                   Foreground="#CCCCCC"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock x:Name="VTKShadowValueText"
                                                                                   Text="0.35"
                                                                                   Foreground="#AAAAAA"
                                                                                   Margin="8,0,0,0"
                                                                                   VerticalAlignment="Center"/>
                                                                </StackPanel>

                                                                <Slider x:Name="SliderVTKShadow"
                                                                        Minimum="0"
                                                                        Maximum="1"
                                                                        Value="0.35"
                                                                        TickFrequency="0.05"
                                                                        IsSnapToTickEnabled="False"
                                                                        ValueChanged="OnVTKShadowValueChanged"
                                                                        Margin="0,0,0,14"/>

                                                                <TextBlock Text="Status"
                                                                           Foreground="White"
                                                                           FontWeight="Bold"
                                                                           FontSize="14"
                                                                           Margin="0,0,0,8"/>

                                                                <TextBlock x:Name="VTKStatusText"
                                                                           Text="VTK panel ready."
                                                                           Foreground="#CCCCCC"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,0,0,10"/>

                                                                <TextBlock x:Name="VTKJsonPathText"
                                                                           Foreground="#888888"
                                                                           FontSize="11"
                                                                           TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                </ScrollViewer>

                                                <ScrollViewer x:Name="VTKChannelsScroll"
                                                              Grid.Row="1"
                                                              VerticalScrollBarVisibility="Auto"
                                                              Visibility="Collapsed">
                                                        <StackPanel Margin="10">
                                                                <TextBlock Text="Ion Channels"
                                                                           Foreground="White"
                                                                           FontWeight="Bold"
                                                                           FontSize="14"
                                                                           Margin="0,0,0,12"/>

                                                                <Button x:Name="BtnReloadVTKChannels"
                                                                        Content="Reload Channels"
                                                                        Click="OnReloadVTKChannelsClick"
                                                                        Background="#3E3E42"
                                                                        Foreground="White"
                                                                        Padding="10,7"
                                                                        HorizontalAlignment="Stretch"
                                                                        Margin="0,0,0,10"/>

                                                                <StackPanel x:Name="VTKChannelListContainer"/>
                                                        </StackPanel>
                                                </ScrollViewer>

                                                <ScrollViewer x:Name="VTKHistoryScroll"
                                                              Grid.Row="1"
                                                              VerticalScrollBarVisibility="Auto"
                                                              Visibility="Collapsed">
                                                        <StackPanel Margin="10">
                                                                <TextBlock Text="History Playback"
                                                                           Foreground="White"
                                                                           FontWeight="Bold"
                                                                           FontSize="14"
                                                                           Margin="0,0,0,12"/>

                                                                <TextBlock x:Name="VTKHistoryStatusText"
                                                                           Text="No simulation history loaded."
                                                                           Foreground="#CCCCCC"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,0,0,10"/>

                                                                <Button x:Name="BtnRefreshVTKHistory"
                                                                        Content="Refresh History"
                                                                        Click="OnRefreshVTKHistoryClick"
                                                                        Background="#3E3E42"
                                                                        Foreground="White"
                                                                        Padding="10,7"
                                                                        HorizontalAlignment="Stretch"
                                                                        Margin="0,0,0,12"/>

                                                                <StackPanel x:Name="VTKHistoryVariableContainer"/>
                                                        </StackPanel>
                                                </ScrollViewer>
                                        </Grid>
                                </Grid>
                        </Border>

                        <!-- Right side: Shared 3D viewport area -->
                        <Grid Grid.Column="1"
                              x:Name="ViewportGrid"
                              ClipToBounds="True">

                                <helix:HelixViewport3D x:Name="MainViewport"
                                                       ShowCoordinateSystem="True"
                                                       CoordinateSystemLabelForeground="White"
                                                       ZoomExtentsWhenLoaded="True"
                                                       ShowViewCube="True"
                                                       MouseDown="OnViewportMouseDown"
                                                       MouseMove="OnViewportMouseMove"
                                                       MouseUp="OnViewportMouseUp"
                                                       MouseWheel="OnViewportMouseWheel">
                                </helix:HelixViewport3D>

                                <!-- VTK mode host area -->
                                <Grid x:Name="VTKViewportRoot"
                                      Visibility="Collapsed"
                                      Background="#111111">
                                        <Border Background="#111111"
                                                ClipToBounds="True">
                                                <vtkTab:VtkHostControl x:Name="VTKHostControl"
                                                                       HorizontalAlignment="Stretch"
                                                                       VerticalAlignment="Stretch"/>
                                        </Border>
                                </Grid>

                                <!-- Crosshair + Coordinate HUD -->
                                <Canvas x:Name="OverlayCanvas"
                                        IsHitTestVisible="False">
                                        <Path x:Name="CrosshairPath"
                                              Stroke="#88FFFFFF"
                                              StrokeThickness="1"
                                              SnapsToDevicePixels="True">
                                                <Path.Data>
                                                        <GeometryGroup>
                                                                <LineGeometry StartPoint="-10,0"
                                                                              EndPoint="10,0"/>
                                                                <LineGeometry StartPoint="0,-10"
                                                                              EndPoint="0,10"/>
                                                        </GeometryGroup>
                                                </Path.Data>
                                        </Path>
                                        <Border x:Name="CoordHud"
                                                Background="#CC000000"
                                                CornerRadius="4"
                                                Padding="5,2"
                                                Canvas.Left="0"
                                                Canvas.Top="0">
                                                <TextBlock x:Name="CoordText"
                                                           Text="X:0 Y:0 Z:0"
                                                           Foreground="#00FF00"
                                                           FontFamily="Consolas"
                                                           FontSize="12"/>
                                        </Border>
                                </Canvas>

                                <!-- Edit Dimensions Popup (Modeling mode) -->
                                <Grid x:Name="EditPopup"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      Width="220">
                                        <Border Background="#DD333333"
                                                BorderBrush="#555"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10">
                                                <Border.Effect>
                                                        <DropShadowEffect BlurRadius="10"
                                                                          ShadowDepth="2"
                                                                          Opacity="0.5"/>
                                                </Border.Effect>
                                                <StackPanel>
                                                        <TextBlock Text="Edit Dimensions"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"
                                                                   Margin="0,0,0,10"/>

                                                        <StackPanel x:Name="PanelAxonLength"
                                                                    Visibility="Collapsed"
                                                                    Margin="0,0,0,5">
                                                                <TextBlock Text="Length:"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"/>
                                                                <TextBox x:Name="TbLength"
                                                                         Background="#222"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"/>
                                                        </StackPanel>

                                                        <StackPanel x:Name="PanelRadius"
                                                                    Visibility="Collapsed"
                                                                    Margin="0,0,0,5">
                                                                <TextBlock Text="Base / Soma Radius:"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"/>
                                                                <TextBox x:Name="TbRadius"
                                                                         Background="#222"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"/>
                                                        </StackPanel>

                                                        <StackPanel x:Name="PanelTopRadius"
                                                                    Visibility="Collapsed"
                                                                    Margin="0,0,0,10">
                                                                <TextBlock Text="Top Radius:"
                                                                           Foreground="#CCC"
                                                                           FontSize="11"/>
                                                                <TextBox x:Name="TbTopRadius"
                                                                         Background="#222"
                                                                         Foreground="White"
                                                                         BorderBrush="#555"/>
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Right">
                                                                <Button Content="Cancel"
                                                                        Click="OnCancelEdit"
                                                                        Width="60"
                                                                        Margin="0,0,5,0"
                                                                        Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                                                                <Button Content="Apply"
                                                                        Click="OnApplyEdit"
                                                                        Width="60"
                                                                        Background="{StaticResource PrimaryActionBrush}"
                                                                        Foreground="White"/>
                                                        </StackPanel>
                                                </StackPanel>
                                        </Border>
                                </Grid>

                                <!-- Modeling mode bottom toolbar -->
                                <Border x:Name="ModelingToolbar"
                                        Visibility="Visible"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Center"
                                        Background="#CC333333"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,20">
                                        <StackPanel Orientation="Horizontal">
                                                <Button Content="Add Soma"
                                                        Click="OnAddSomaClick"
                                                        Background="{StaticResource PrimaryActionBrush}"
                                                        Foreground="White"
                                                        Padding="10,5"
                                                        Margin="5"/>
                                                <Button Content="Add Axon"
                                                        Click="OnAddAxonClick"
                                                        Background="{StaticResource PrimaryActionBrush}"
                                                        Foreground="White"
                                                        Padding="10,5"
                                                        Margin="5"/>
                                                <Button Content="Add Dend"
                                                        Click="OnAddDendClick"
                                                        Background="{StaticResource PrimaryActionBrush}"
                                                        Foreground="White"
                                                        Padding="10,5"
                                                        Margin="5"/>
                                        </StackPanel>
                                </Border>

                                <!-- Simulation mode bottom toolbar -->
                                <Border x:Name="SimulationToolbar"
                                        Visibility="Collapsed"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Center"
                                        Background="#CC333333"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,20">
                                        <StackPanel Orientation="Horizontal">
                                                <Button Content="Add CurrentClamp"
                                                        Click="OnAddStimulationClick"
                                                        Background="{StaticResource PrimaryActionBrush}"
                                                        Foreground="White"
                                                        Padding="10,5"
                                                        Margin="5"/>
                                                <Button Content="Add VoltageClamp"
                                                        Click="OnAddVoltageClampClick"
                                                        Background="{StaticResource PrimaryActionBrush}"
                                                        Foreground="White"
                                                        Padding="10,5"
                                                        Margin="5"/>
                                                <Button Content="Add Probe"
                                                        Click="OnAddProbeClick"
                                                        Background="{StaticResource PrimaryActionBrush}"
                                                        Foreground="White"
                                                        Padding="10,5"
                                                        Margin="5"/>
                                        </StackPanel>
                                </Border>

                        </Grid>

                        <!-- Channel selector popup -->
                        <Popup x:Name="ChannelSelectorPopup"
                               StaysOpen="False"
                               Placement="MousePoint">
                                <Border Background="#333333"
                                        BorderBrush="#555555"
                                        BorderThickness="1"
                                        Padding="10">
                                        <StackPanel>
                                                <TextBlock Text="Select Channel to Add:"
                                                           Foreground="#CCCCCC"
                                                           Margin="0,0,0,5"/>
                                                <StackPanel x:Name="ChannelSelectorList"/>
                                        </StackPanel>
                                </Border>
                        </Popup>

                </Grid>
        </Grid>
</Window>
